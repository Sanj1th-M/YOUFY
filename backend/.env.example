# Server
PORT=3000
NODE_ENV=development

# Firebase Admin SDK (get from Firebase Console -> Service Accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# yt-dlp cookie auth (refresh every 2-3 months)
# Path to exported cookies.txt file from your server browser
YT_DLP_COOKIES=

# OR let yt-dlp read directly from an installed browser (chrome/firefox/edge)
# Only works if browser is installed on the same machine as the backend
YT_DLP_COOKIES_FROM_BROWSER=

# Optional: proxy for yt-dlp if your server IP gets rate limited by YouTube
# Format: socks5://user:pass@host:port or http://host:port
YT_DLP_PROXY=

# CORS -> set your actual frontend domain in production
FRONTEND_URL=https://youfy.vercel.app

# Public backend origin for OAuth callback URLs
PUBLIC_BACKEND_URL=http://localhost:3000

# Playlist import feature flag and rollout percentage
PLAYLIST_IMPORT_ENABLED=false
PLAYLIST_IMPORT_ROLLOUT_PERCENT=10

# 32-byte AES-256 key encoded as base64 or hex
PLAYLIST_IMPORT_ENCRYPTION_KEY=

# Redis connection used by BullMQ and provider search cache
REDIS_URL=

# Spotify OAuth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google OAuth client for YouTube Music imports
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
